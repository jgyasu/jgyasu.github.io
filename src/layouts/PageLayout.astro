---
/** Simple layout for standalone content pages (About, listings, etc.). */
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  /** Optional intro/lede shown under the page title. */
  lede?: string;
  wide?: boolean;
}

const { title, description, lede, wide = false } = Astro.props;
---

<BaseLayout title={title} description={description} wide={wide}>
  <div class="page fade-in">
    <header class="page-header">
      <h1>{title}</h1>
      {lede && <p class="page-lede muted">{lede}</p>}
    </header>
    <slot />
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: var(--space-8);
  }
  .page-lede {
    font-size: 1.1rem;
    margin-top: var(--space-3);
    margin-bottom: 0;
  }
</style>
