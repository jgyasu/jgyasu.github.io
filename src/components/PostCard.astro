---
import type { BlogPost } from "@/lib/utils";
import { tagToSlug } from "@/lib/utils";
import FormattedDate from "./FormattedDate.astro";

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
---

<article class="post-card">
  <h2 class="post-card-title">
    <a href={`/blog/${post.id}`}>{title}</a>
  </h2>
  <p class="post-card-meta meta">
    <FormattedDate date={pubDate} />
    {tags.length > 0 && <span aria-hidden="true"> · </span>}
    {tags.length > 0 && (
      <span class="post-card-tags">
        {tags.map((tag) => (
          <a class="tag" href={`/blog/tags/${tagToSlug(tag)}`}>{tag}</a>
        ))}
      </span>
    )}
  </p>
  <p class="post-card-desc muted">{description}</p>
</article>

<style>
  .post-card {
    padding-block: var(--space-6);
    border-bottom: 1px solid var(--border);
  }
  .post-card-title {
    margin: 0 0 var(--space-2);
    font-size: 1.3rem;
  }
  .post-card-title a {
    color: var(--text);
  }
  .post-card-title a:hover {
    color: var(--accent);
  }
  .post-card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin: 0 0 var(--space-2);
  }
  .post-card-tags {
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .post-card-desc {
    margin: 0;
  }
</style>
