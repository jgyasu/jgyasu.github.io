---
/**
 * Lightweight client-side search. Fetches /search.json on first focus and
 * filters in-memory. Progressive enhancement: with JavaScript disabled the
 * input simply does nothing and the full listing remains usable.
 */
import { withBase } from "@/lib/paths";

interface Props {
  placeholder?: string;
}

const { placeholder = "Search…" } = Astro.props;
const indexUrl = withBase("/search.json");
---

<div class="search" data-index={indexUrl}>
  <label class="sr-only" for="search-input">Search</label>
  <input
    id="search-input"
    class="search-input"
    type="search"
    placeholder={placeholder}
    autocomplete="off"
    spellcheck="false"
    aria-describedby="search-status"
  />
  <p id="search-status" class="search-status meta" role="status" aria-live="polite"></p>
  <ul id="search-results" class="search-results" hidden></ul>
</div>

<style>
  .search {
    margin-bottom: var(--space-8);
  }
  .search-input {
    width: 100%;
    font: inherit;
    font-size: 1rem;
    padding: var(--space-3) var(--space-4);
    color: var(--text);
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color var(--transition);
  }
  .search-input:focus {
    outline: none;
    border-color: var(--accent);
  }
  .search-status {
    margin: var(--space-2) 0 0;
    min-height: 1.2em;
  }
  .search-results {
    list-style: none;
    padding: 0;
    margin: var(--space-2) 0 0;
  }
  .search-results li {
    margin: 0;
    border-bottom: 1px solid var(--border);
  }
  .search-results a {
    display: block;
    padding: var(--space-3) 0;
    color: var(--text);
  }
  .search-results a:hover,
  .search-results a:focus {
    color: var(--accent);
    text-decoration: none;
  }
  .result-type {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-faint);
    margin-inline-start: var(--space-2);
  }
  .result-desc {
    display: block;
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-top: 2px;
  }
</style>

<script>
  type Item = {
    type: string;
    title: string;
    description: string;
    tags: string[];
    url: string;
    body: string;
  };

  const root = document.querySelector<HTMLElement>(".search");
  const input = document.getElementById("search-input") as HTMLInputElement | null;
  const results = document.getElementById("search-results") as HTMLUListElement | null;
  const status = document.getElementById("search-status");

  if (root && input && results && status) {
    const indexUrl = root.dataset.index || "/search.json";
    let items: Item[] | null = null;
    let loading = false;

    async function ensureIndex() {
      if (items || loading) return;
      loading = true;
      try {
        const res = await fetch(indexUrl);
        items = (await res.json()) as Item[];
      } catch {
        status!.textContent = "Search is unavailable.";
      } finally {
        loading = false;
      }
    }

    function escapeHtml(s: string) {
      return s.replace(/[&<>"']/g, (c) => {
        const map: Record<string, string> = {
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;",
        };
        return map[c];
      });
    }

    function score(item: Item, q: string): number {
      const hay = (item.title + " " + item.tags.join(" ")).toLowerCase();
      if (item.title.toLowerCase().includes(q)) return 3;
      if (hay.includes(q)) return 2;
      if ((item.description + " " + item.body).toLowerCase().includes(q)) return 1;
      return 0;
    }

    function render(q: string) {
      if (!items) return;
      const query = q.trim().toLowerCase();
      if (query.length < 2) {
        results!.hidden = true;
        results!.innerHTML = "";
        status!.textContent = "";
        return;
      }
      const matches = items
        .map((item) => ({ item, s: score(item, query) }))
        .filter((m) => m.s > 0)
        .sort((a, b) => b.s - a.s)
        .slice(0, 20);

      status!.textContent = `${matches.length} result${matches.length === 1 ? "" : "s"}`;
      results!.hidden = matches.length === 0;
      results!.innerHTML = matches
        .map(
          ({ item }) => `
          <li>
            <a href="${item.url}">
              ${escapeHtml(item.title)}<span class="result-type">${item.type}</span>
              ${item.description ? `<span class="result-desc">${escapeHtml(item.description)}</span>` : ""}
            </a>
          </li>`,
        )
        .join("");
    }

    input.addEventListener("focus", ensureIndex, { once: true });
    input.addEventListener("input", () => render(input.value));
  }
</script>
