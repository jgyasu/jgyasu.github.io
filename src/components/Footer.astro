---
import { site, socialLinks } from "@/site.config";

const year = new Date().getFullYear();

// External links get the right rel attributes; mailto links do not.
function isExternal(href: string): boolean {
  return href.startsWith("http");
}
---

<footer class="site-footer">
  <div class="container container-wide footer-inner">
    <p class="copyright">© {year} {site.name}</p>

    <nav aria-label="Social">
      <ul class="social-list">
        {
          socialLinks.map((link) => (
            <li>
              <a
                href={link.href}
                rel={isExternal(link.href) ? "me noopener noreferrer" : undefined}
                target={isExternal(link.href) ? "_blank" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    padding-block: var(--space-8);
    margin-top: var(--space-16);
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }
  .copyright {
    margin: 0;
  }
  .social-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .social-list a {
    color: var(--text-muted);
  }
  .social-list a:hover {
    color: var(--text);
  }
</style>
