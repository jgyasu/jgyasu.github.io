---
/** A project card with title, description, tech pills, and links. */
import type { Project } from "@/lib/utils";

interface Props {
  project: Project;
}

const { project } = Astro.props;
const { title, description, tech, github, demo, image } = project.data;
---

<article class="project-card">
  {image && (
    <a href={demo ?? github ?? "#"} class="project-thumb" tabindex="-1" aria-hidden="true">
      <img src={image} alt="" loading="lazy" decoding="async" width="800" height="450" />
    </a>
  )}
  <div class="project-body">
    <h2 class="project-title">{title}</h2>
    <p class="project-desc muted">{description}</p>

    {tech.length > 0 && (
      <ul class="tag-list project-tech">
        {tech.map((t) => <li class="tag">{t}</li>)}
      </ul>
    )}

    <div class="project-links">
      {github && (
        <a href={github} rel="noopener noreferrer" target="_blank">Source ↗</a>
      )}
      {demo && (
        <a href={demo} rel="noopener noreferrer" target="_blank">Live demo ↗</a>
      )}
    </div>
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface);
    transition: border-color var(--transition), transform var(--transition);
  }
  .project-card:hover {
    border-color: var(--text-faint);
  }
  .project-thumb {
    display: block;
    border-bottom: 1px solid var(--border);
    background: var(--bg-subtle);
  }
  .project-thumb img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  .project-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
  }
  .project-title {
    margin: 0;
    font-size: 1.2rem;
  }
  .project-desc {
    margin: 0;
    flex: 1;
  }
  .project-tech {
    margin: 0;
  }
  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    font-size: 0.95rem;
  }
</style>
