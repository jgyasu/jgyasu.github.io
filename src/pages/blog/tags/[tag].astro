---
import type { GetStaticPaths } from "astro";
import { getPosts, getTagCounts, tagToSlug } from "@/lib/utils";
import PageLayout from "@/layouts/PageLayout.astro";
import PostCard from "@/components/PostCard.astro";

// One page per tag, listing every post that uses it.
export const getStaticPaths = (async () => {
  const posts = await getPosts();
  const tagCounts = await getTagCounts();
  return [...tagCounts.keys()].map((tag) => ({
    params: { tag: tagToSlug(tag) },
    props: {
      tag,
      posts: posts.filter((p) => p.data.tags.includes(tag)),
    },
  }));
}) satisfies GetStaticPaths;

const { tag, posts } = Astro.props;
---

<PageLayout
  title={`#${tag}`}
  description={`Posts tagged "${tag}".`}
  lede={`${posts.length} ${posts.length === 1 ? "post" : "posts"} tagged "${tag}".`}
>
  <p class="back"><a href="/blog/tags">← All tags</a></p>
  <div class="post-list">
    {posts.map((post) => <PostCard post={post} />)}
  </div>
</PageLayout>

<style>
  .back {
    margin-bottom: var(--space-4);
  }
  .post-list :global(.post-card:first-child) {
    border-top: 1px solid var(--border);
  }
</style>
